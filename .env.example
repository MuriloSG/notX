# =============================================================
# notX — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# Todas as instâncias da API e do Worker devem usar as mesmas
# variáveis para garantir consistência em escala.
# =============================================================


# -------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# Em produção, use uma string de conexão segura com SSL.
# -------------------------------------------------------------
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=notxdb;Username=postgres;Password=postgres


# -------------------------------------------------------------
# SMTP — Gmail
#
# Para usar com o Gmail:
#   1. Acesse: https://myaccount.google.com/security
#   2. Ative a autenticação de dois fatores
#   3. Vá em "Senhas de app" e gere uma senha exclusiva para o notX
#   4. Use essa senha gerada em SMTP_PASSWORD (NÃO use sua senha normal)
#
# Em produção, prefira um serviço dedicado (SendGrid, SES, Mailgun).
# -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USERNAME=seu-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=notX
SMTP_FROM_EMAIL=seu-email@gmail.com


# -------------------------------------------------------------
# TWILIO — SMS
#
# Obtenha suas credenciais em: https://console.twilio.com
#   - Account SID: visível no painel principal (começa com "AC")
#   - Auth Token: visível no painel principal (clique para revelar)
#   - From Number: número Twilio adquirido com suporte a SMS
#     Formato obrigatório: E.164 — ex: +5511999999999
#
# Conta trial: só envia para números verificados.
# Para produção, faça upgrade da conta.
# -------------------------------------------------------------
Twilio__AccountSid=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Twilio__AuthToken=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Twilio__FromNumber=+5511999999999
